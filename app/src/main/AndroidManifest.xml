<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- 侧载自升级 APK（Android 8+） -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />
    <!-- ConnectivityManager.getActiveNetwork / NetworkCapabilities（EchoCard 权限卡片等） -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- 与 iOS 声音克隆录制对齐 -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <!-- 自管理 ConnectionService / PhoneAccount（延迟测试假来电）；无此权限 registerPhoneAccount 会 SecurityException -->
    <uses-permission android:name="android.permission.MANAGE_OWN_CALLS" />

    <!-- API 23–30：BLE 扫描需定位权限（系统要求）；API 31+ 用 BLUETOOTH_SCAN+neverForLocation，不再依赖定位 -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" android:maxSdkVersion="30" />
    <!-- BLE 设备绑定：与 iOS NSBluetoothAlwaysUsageDescription 对齐 -->
    <uses-permission android:name="android.permission.BLUETOOTH" android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN" android:usesPermissionFlags="neverForLocation" tools:targetApi="s" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <!-- 应用自行发出通知（如来电转写等）；非读取系统通知。Android 13+ 需运行时授权 -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- 通话态前台服务（API 28+）；connectedDevice 类型（API 34+）与 BLE 代接链路对齐 -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" />
    <!-- 实验：来电状态/号码广播（号码在 Android 10+ 常受限） -->
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    <uses-feature android:name="android.hardware.bluetooth_le" android:required="true" />

    <application
        android:name=".CallMateApplication"
        android:enableOnBackInvokedCallback="true"
        android:networkSecurityConfig="@xml/network_security_config"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.CallMate">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.CallMate">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- 深链：与 iOS callmate://livecall 一致，用于进行中通话/挂断等 -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="callmate" android:host="livecall" android:pathPrefix="/" />
            </intent-filter>
        </activity>
        <!-- 阶段3：与 iOS CallKit 等价的电话集成占位，后续实现来电/接听同步 -->
        <service
            android:name=".core.telecom.CallMateConnectionService"
            android:exported="true"
            android:permission="android.permission.BIND_TELECOM_CONNECTION_SERVICE">
            <intent-filter>
                <action android:name="android.telecom.ConnectionService" />
            </intent-filter>
        </service>
        <service
            android:name=".features.calls.CallForegroundService"
            android:exported="false"
            android:foregroundServiceType="connectedDevice" />
        <service
            android:name=".core.telecom.CallMateInCallService"
            android:exported="true"
            android:permission="android.permission.BIND_INCALL_SERVICE">
            <intent-filter>
                <action android:name="android.telecom.InCallService" />
            </intent-filter>
            <meta-data
                android:name="android.telecom.IN_CALL_SERVICE_RINGING"
                android:value="true" />
            <meta-data
                android:name="android.telecom.IN_CALL_SERVICE_UI"
                android:value="true" />
        </service>
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="com.vaca.callmate.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>

</manifest>